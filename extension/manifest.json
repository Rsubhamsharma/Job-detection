{
  "manifest_version": 3,
  "name": "JobZoid",
  "version": "1.0",
  "description": "Applicant Energy Sink Detector - HireGuard Security Extension",
  "permissions": ["tabs", "storage", "scripting", "alarms"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://linkedin.com/jobs/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "public/popup.html",
    "default_title": "JobZoid"
  },
  "content_scripts": [{
    "matches": [
      "https://www.linkedin.com/jobs/*",
      "https://linkedin.com/jobs/*"
    ],
    "js": ["src/content.js"]
  }]
}
